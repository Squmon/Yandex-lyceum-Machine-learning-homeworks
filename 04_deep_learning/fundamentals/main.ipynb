   "source": [
    "import numpy as np\n",
    "\n",
    "\n",
    "def calculate_inception_score(matrix, epsilon):\n",
    "    Q = np.sum(matrix, 0) / len(matrix)\n",
    "    return round(np.exp(np.sum(matrix * np.log((matrix + epsilon) / (Q + epsilon))) / len(matrix)), 3)"
   ]
  }
